---
import type { TranslationKey } from '../i18n/utils'

interface Props {
  t: (key: TranslationKey) => string
}

const { t } = Astro.props
---

<footer class="border-t border-white/[0.06] px-6 py-8">
  <div
    class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 text-sm text-gray-500 sm:flex-row"
  >
    <span>{t('footer_copyright')}</span>
    <div class="flex items-center gap-6">
      <a
        href="https://rs-grid.com"
        class="transition-colors hover:text-gray-300"
        target="_blank"
        rel="noopener noreferrer"
      >
        rs-grid.com
      </a>
      <a
        href="https://github.com/ruxelion"
        class="transition-colors hover:text-gray-300"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
      </a>
    </div>
  </div>
</footer>
