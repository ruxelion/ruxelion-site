---
import type { Lang, TranslationKey } from '../i18n/utils'

interface Props {
  lang: Lang
  t: (key: TranslationKey) => string
}

const { lang, t } = Astro.props
const rsGridUrl =
  lang === 'fr'
    ? 'https://rs-grid.com/fr/getting-started'
    : 'https://rs-grid.com/getting-started'
---

<section
  class="relative flex min-h-screen items-center justify-center overflow-hidden px-6 pt-16"
>
  <!-- Background glows -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div
      class="absolute inset-0 bg-gradient-to-br from-[#0a0f1e] via-[#0a0f1e] to-[#0f1629]"
    >
    </div>
    <div
      class="absolute top-1/2 left-1/2 h-[700px] w-[700px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-blue-600/[0.06] blur-3xl"
    >
    </div>
    <div
      class="absolute top-1/3 left-1/4 h-[350px] w-[350px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-blue-500/[0.04] blur-2xl"
    >
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-4xl text-center">
    <!-- Badge -->
    <div
      class="mb-8 inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-4 py-1.5"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-blue-400"></span>
      <span class="text-sm font-medium text-blue-300">{t('hero_badge')}</span>
    </div>

    <!-- Title -->
    <h1
      class="mb-6 text-5xl leading-tight font-extrabold tracking-tight text-white md:text-6xl lg:text-7xl"
    >
      {t('hero_title_1')}<br />
      <span
        class="bg-gradient-to-r from-blue-400 to-blue-600 bg-clip-text text-transparent"
      >
        {t('hero_title_2')}
      </span>
    </h1>

    <!-- Subtitle -->
    <p
      class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-gray-400 md:text-xl"
    >
      {t('hero_sub')}
    </p>

    <!-- CTAs -->
    <div
      class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
    >
      <a
        href={rsGridUrl}
        class="group inline-flex items-center gap-2 rounded-xl bg-blue-600 px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-blue-900/30 transition-all hover:bg-blue-500 hover:shadow-blue-800/40"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t('hero_cta_primary')}
        <svg
          class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
            clip-rule="evenodd"></path>
        </svg>
      </a>

      <a
        href="https://github.com/ruxelion/rs-grid"
        class="inline-flex items-center gap-2 rounded-xl border border-white/10 px-7 py-3.5 text-base font-semibold text-gray-200 transition-all hover:border-white/20 hover:text-white"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
          ></path>
        </svg>
        {t('hero_cta_secondary')}
      </a>
    </div>
  </div>
</section>
