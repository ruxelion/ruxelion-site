---
import type { Lang, TranslationKey } from '../i18n/utils'

interface Props {
  lang: Lang
  t: (key: TranslationKey) => string
}

const { lang, t } = Astro.props
const homeHref = lang === 'fr' ? '/fr/' : '/'
---

<header
  class="fixed top-0 right-0 left-0 z-50 border-b border-white/[0.08] bg-[#0a0f1e]/90 backdrop-blur-md"
>
  <nav
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6"
    aria-label="Main navigation"
  >
    <a href={homeHref} class="flex items-center" aria-label="Ruxelion home">
      <img
        src="/images/logo-dark.png"
        alt="Ruxelion"
        class="h-8 w-auto"
        width="120"
        height="32"
      />
    </a>

    <div class="flex items-center gap-2 sm:gap-6">
      <a
        href="https://rs-grid.com"
        class="hidden text-sm font-medium text-gray-300 transition-colors hover:text-white sm:inline"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t('nav_rs_grid')}
      </a>

      <a
        href={t('lang_switch_href')}
        class="text-sm font-medium text-gray-400 transition-colors hover:text-white"
        aria-label="Switch language"
      >
        {t('lang_switch')}
      </a>

      <a
        href="https://github.com/ruxelion"
        class="inline-flex items-center gap-2 rounded-lg border border-white/10 px-4 py-2 text-sm font-medium text-gray-200 transition-all hover:border-white/25 hover:text-white"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
          ></path>
        </svg>
        <span class="hidden sm:inline">{t('nav_github')}</span>
      </a>
    </div>
  </nav>
</header>
